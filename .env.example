# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
BOT_USER_ID=U...

# Slack search (user token with search:read scope — needed for cross-channel search)
SLACK_USER_TOKEN=xoxp-...

# Agentic harness — 'openai' (in-process OpenAI Agents SDK loop, default) or
# 'cli' (legacy Claude CLI subprocess, kept as instant rollback). 'openai'
# requires OPENAI_API_KEY (or MEMORY_EMBEDDING_API_KEY) below.
HARNESS=openai
# Legacy 'cli' harness only — path to the Claude CLI binary.
CLAUDE_BIN=claude

# OpenAI — powers the 'openai' harness reply loop AND fact extraction + embeddings.
# Required when HARNESS=openai (MEMORY_EMBEDDING_API_KEY is accepted as a fallback).
OPENAI_API_KEY=sk-...
# Default model for the 'openai' harness reply loop (GPT-5-class). The SDK's own
# default is gpt-5.4-mini; bump to a larger GPT-5-class tier for more headroom
# (add its official price to src/llm/modelPricing.ts first).
OPENAI_REPLY_MODEL=gpt-5.4-mini
# Agent-loop cost guards (openai harness): hard turn cap + optional cumulative
# output-token budget that aborts the loop when exceeded.
AGENT_MAX_TURNS=12
# Optional cumulative token budget; the agent loop aborts once exceeded.
# AGENT_TOKEN_BUDGET=
# Optional allowlist of MCP servers for the GENERAL route (comma-separated),
# to cap the tool surface; memory is always included. Unset = all credentialed.
# GENERAL_MCP_SERVERS=metabase,slack-search,gmail
# Optional model pin for the analytics route (defaults to OPENAI_REPLY_MODEL).
# ANALYTICS_MODEL=

# Organizational memory (fact extraction runs on the OpenAI key above)
# Extra internal email domains allowed into memory ingestion, comma-separated (newtonschool.co is always allowlisted)
MEMORY_GMAIL_DOMAINS=
# Set to 0 to disable Meet-transcript ingestion into memory (read per tick — no rebuild needed)
MEMORY_INGEST_MEET=1
# Set to 0 to disable internal-Gmail ingestion into memory (read per tick — no rebuild needed)
MEMORY_INGEST_GMAIL=1

# Metabase
METABASE_URL=https://metabase.example.com
METABASE_USERNAME=admin@example.com
METABASE_PASSWORD=
# Recommended for headless/EC2 + SSO Metabase — mint at <METABASE_URL>/admin/settings/authentication/api-keys.
# Set EITHER METABASE_API_KEY OR METABASE_USERNAME+METABASE_PASSWORD.
METABASE_API_KEY=

# GitHub
GITHUB_TOKEN=ghp_...

# Notion
NOTION_API_KEY=ntn_...

# Google Workspace (for Gmail, Calendar, Drive/Docs transcripts, and Google Meet API v2)
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials,
# then mint GOOGLE_REFRESH_TOKEN with `node scripts/google-auth.js <CLIENT_ID> <CLIENT_SECRET>`.
# The token must include ALL five scopes that google-auth.js requests:
#   - gmail.readonly            (gmail.ts)
#   - calendar.readonly         (calendar.ts)
#   - drive.readonly            (transcripts.ts — Drive file search)
#   - documents.readonly        (transcripts.ts — Google Docs body read)
#   - meetings.space.readonly   (meet.ts — Meet REST API v2; REQUIRED for the Meet tools)
# A token minted without meetings.space.readonly will leave the google-meet MCP server unable
# to read conference records/transcripts — re-run google-auth.js to add it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Health check
HEALTH_CHECK_PORT=8930

# Storage
SQLITE_DB_PATH=./sentinel.db

# Access control (comma-separated Slack user IDs)
ALLOWED_USER_IDS=U123,U456

# Logging
LOG_LEVEL=info
