# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
BOT_USER_ID=U...

# Slack search (user token with search:read scope — needed for cross-channel search)
SLACK_USER_TOKEN=xoxp-...

# Claude
CLAUDE_BIN=claude
ANTHROPIC_API_KEY=sk-ant-...

# Metabase
METABASE_URL=https://metabase.example.com
METABASE_USERNAME=admin@example.com
METABASE_PASSWORD=

# GitHub
GITHUB_TOKEN=ghp_...

# Notion
NOTION_API_KEY=ntn_...

# Google Workspace (for Gmail, Calendar, Drive/Docs transcripts, and Google Meet API v2)
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials,
# then mint GOOGLE_REFRESH_TOKEN with `node scripts/google-auth.js <CLIENT_ID> <CLIENT_SECRET>`.
# The token must include ALL five scopes that google-auth.js requests:
#   - gmail.readonly            (gmail.ts)
#   - calendar.readonly         (calendar.ts)
#   - drive.readonly            (transcripts.ts — Drive file search)
#   - documents.readonly        (transcripts.ts — Google Docs body read)
#   - meetings.space.readonly   (meet.ts — Meet REST API v2; REQUIRED for the Meet tools)
# A token minted without meetings.space.readonly will leave the google-meet MCP server unable
# to read conference records/transcripts — re-run google-auth.js to add it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Health check
HEALTH_CHECK_PORT=8080

# Storage
SQLITE_DB_PATH=./sentinel.db

# Access control (comma-separated Slack user IDs)
ALLOWED_USER_IDS=U123,U456

# Logging
LOG_LEVEL=info
