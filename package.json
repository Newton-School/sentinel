{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "Leadership data bot — business insights via Slack powered by the OpenAI Agents SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dashboard": "tsx src/dashboard/index.ts",
    "dashboard:start": "node dist/dashboard/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "meet-bot:setup": "tsx src/meet-bot/setup.ts",
    "meet-bot:join": "tsx src/meet-bot/joiner.ts",
    "monitor:memory": "tsx scripts/monitor-memory.ts",
    "eval": "tsx evals/runner.ts",
    "eval:gate": "tsx evals/runner.ts --gate",
    "eval:analytics": "tsx evals/runner.ts --suite analytics --judge --threshold 0.7",
    "feedback:harvest": "tsx scripts/harvest-feedback.ts",
    "grafana:validate": "tsx scripts/provision-grafana.ts",
    "grafana:provision": "tsx scripts/provision-grafana.ts --apply"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/agents": "^0.11.8",
    "@slack/bolt": "^4.3.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.5.0",
    "googleapis": "^171.4.0",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.22.0",
    "pino": "^9.6.0",
    "playwright": "^1.59.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
