# Keep the build context lean and prevent secrets/local state from leaking into
# the image. The Dockerfile uses explicit COPY (package*.json, tsconfig.json,
# src/) so most of these aren't copied today — this is defense-in-depth in case
# the COPY logic ever changes to a glob.
node_modules
dist
# SPA package (built fresh inside Dockerfile.dashboard). The bare node_modules/
# dist above only match the repo root, so the nested ones need explicit entries.
dashboard-web/node_modules
dashboard-web/dist
.env
.env.*
*.db
*.db-wal
*.db-shm
data/
.git
.gitignore
*.log
.DS_Store
evals/results/
coverage/
.claude/
